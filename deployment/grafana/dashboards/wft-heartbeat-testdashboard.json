          "expr": "sum by (workflow_type, failure_reason) (rate(temporal_workflow_task_execution_failed{namespace=\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "{{workflow_type}} / {{failure_reason}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "WFT Poll Succeed Rate",
      "description": "Rate of polls that returned a task. A drop here while WFT timeouts rise may indicate workers are not polling fast enough. Metric: temporal_workflow_task_queue_poll_succeed",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 31
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "min",
            "max",
            "mean",
            "lastNotNull"
          ]
