      "targets": [
        {
          "expr": "sum by (workflow_type, task_queue) (rate(temporal_workflow_task_queue_poll_succeed{namespace=\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "{{workflow_type}} / {{task_queue}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Go SDK \u2014 Local Activity Duration (Root Cause)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 38
