{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 200,
      "title": "Workflow Stats",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 4, "x": 0, "y": 1 },
      "id": 201,
      "title": "Workflow Success",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(workflow_success{namespace=\"$namespace\"}[$rate]))", "legendFormat": "success/s", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 4, "x": 4, "y": 1 },
      "id": 202,
      "title": "Workflow Cancel",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(workflow_cancel{namespace=\"$namespace\"}[$rate]))", "legendFormat": "cancel/s", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 4, "x": 8, "y": 1 },
      "id": 203,
      "title": "Workflow Failed",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(workflow_failed{namespace=\"$namespace\"}[$rate]))", "legendFormat": "failed/s", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 4, "x": 12, "y": 1 },
      "id": 204,
      "title": "Workflow Timeout",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(workflow_timeout{namespace=\"$namespace\"}[$rate]))", "legendFormat": "timeout/s", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 4, "x": 16, "y": 1 },
      "id": 205,
      "title": "Workflow Terminate",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(workflow_terminate{namespace=\"$namespace\"}[$rate]))", "legendFormat": "terminate/s", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 4, "x": 20, "y": 1 },
      "id": 206,
      "title": "Workflow Continued As New",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(workflow_continued_as_new{namespace=\"$namespace\"}[$rate]))", "legendFormat": "continued-as-new/s", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "id": 1,
      "title": "Server Overview — Cluster Throughput",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 9 },
      "id": 9,
      "title": "Server State Transitions",
      "description": "Server state transitions per second",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(state_transition_count_count{namespace=\"$namespace\"}[$rate]))", "legendFormat": "state transitions/s", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 9 },
      "id": 14,
      "title": "Shard Lock Latency (p99)",
      "description": "P99 latency for acquiring the shard lock (ShardInfo semaphore) on the History service.",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile($p, sum by (le) (rate(semaphore_latency_bucket{operation=\"ShardInfo\",service_name=\"history\",namespace=\"$namespace\"}[$rate])))", "legendFormat": "p{{p}} shard lock latency", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 7,
      "title": "Server Overview — Persistence Requests, Latencies and Errors",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 17 },
      "id": 70,
      "title": "Persistence Requests",
      "description": "Rate of persistence requests by operation.",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(persistence_requests{namespace=\"$namespace\"}[$rate])) by (operation)", "legendFormat": "{{operation}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 17 },
      "id": 71,
      "title": "Persistence Latencies",
      "description": "Persistence latencies broken down by operation.",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile($p, sum(rate(persistence_latency_bucket{namespace=\"$namespace\"}[$rate])) by (operation, le))", "legendFormat": "{{operation}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 17 },
      "id": 72,
      "title": "Persistence Errors",
      "description": "Rate of persistence errors by operation and error type.",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(persistence_error_with_type{namespace=\"$namespace\"}[$rate])) by (operation, error_type)", "legendFormat": "{{operation}} — {{error_type}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 17 },
      "id": 73,
      "title": "Persistence Availability",
      "description": "Percentage of persistence requests that succeeded (no errors).",
      "type": "timeseries",
      "targets": [
        { "expr": "100 - (sum(rate(persistence_errors{namespace=\"$namespace\"}[$rate]) or on () vector(0)) / sum(rate(persistence_requests{namespace=\"$namespace\"}[$rate])) * 100)", "legendFormat": "availability %", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 90,
      "title": "Server Overview — Service Requests and Errors",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 25 },
      "id": 91,
      "title": "Service Requests",
      "description": "Rate of service requests on the Frontend service.",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(service_requests{service_name=\"frontend\",namespace=\"$namespace\"}[$rate]) or on () vector(0))", "legendFormat": "requests/s", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 25 },
      "id": 92,
      "title": "Service Errors",
      "description": "Rate of service errors on the Frontend service.",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(service_errors{service_name=\"frontend\",namespace=\"$namespace\"}[$rate]) or on () vector(0))", "legendFormat": "errors/s", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 32 },
      "id": 93,
      "title": "Service Requests by Namespace",
      "description": "Rate of frontend service requests broken down across all namespaces.",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (namespace) (rate(service_requests{service_name=\"frontend\"}[$rate]) or on () vector(0))", "legendFormat": "{{namespace}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 39 },
      "id": 94,
      "title": "Server Errors by Type",
      "description": "Rate of frontend service errors broken down by error type.",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (error_type) (rate(service_error_with_type{service_name=\"frontend\",namespace=\"$namespace\"}[$rate]))", "legendFormat": "{{error_type}}", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 46 },
      "id": 100,
      "title": "Server Overview — Key API Latencies",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 47 },
      "id": 101,
      "title": "Key API Latencies by Operation",
      "description": "Latencies for key workflow and activity API operations on the Frontend service.",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile($p, sum by (operation, le) (rate(service_latency_bucket{operation=~\"StartWorkflowExecution|SignalWorkflowExecution|RespondWorkflowTaskCompleted|RespondActivityTaskCompleted\",service_name=\"frontend\",namespace=\"$namespace\"}[$rate])))", "legendFormat": "{{operation}}", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 54 },
      "id": 120,
      "title": "Server Overview — Throttling",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 55 },
      "id": 121,
      "title": "Resource Exhausted with Cause",
      "description": "Rate of resource exhausted errors broken down by operation and cause.",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(service_errors_resource_exhausted{namespace=\"$namespace\"}[$rate])) by (operation, resource_exhausted_cause)", "legendFormat": "{{operation}} — {{resource_exhausted_cause}}", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 62 },
      "id": 110,
      "title": "Server Overview — SDK Workers",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 63 },
      "id": 111,
      "title": "Schedule to Start Latencies",
      "description": "Latency from task scheduling to task start, broken down by task type and operation.",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile($p, sum(rate(task_schedule_to_start_latency_bucket{namespace=\"$namespace\"}[$rate])) by (task_type, operation, le))", "legendFormat": "{{task_type}} — {{operation}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 70 },
      "id": 112,
      "title": "Tasks Persisted to DB (can indicate task backlog)",
      "description": "Rate of CreateTasks persistence requests. A sustained increase may indicate a task backlog building up.",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(persistence_requests{operation=\"CreateTasks\",namespace=\"$namespace\"}[$rate]))", "legendFormat": "tasks persisted/s", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 77 },
      "id": 6,
      "title": "Server Overview — Shard Movement",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 78 },
      "id": 60,
      "title": "Shards Created",
      "description": "Rate of shard items created on the History service.",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(sharditem_created_count{service_name=\"history\",namespace=\"$namespace\"}[$rate]))", "legendFormat": "shards created/s", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 78 },
      "id": 61,
      "title": "Shards Removed",
      "description": "Rate of shard items removed on the History service.",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(sharditem_removed_count{service_name=\"history\",namespace=\"$namespace\"}[$rate]))", "legendFormat": "shards removed/s", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 78 },
      "id": 62,
      "title": "Shards Closed",
      "description": "Rate of shard items closed on the History service.",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(sharditem_closed_count{service_name=\"history\",namespace=\"$namespace\"}[$rate]))", "legendFormat": "shards closed/s", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 85 },
      "id": 8,
      "title": "Server Overview — Visibility",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 86 },
      "id": 80,
      "title": "Visibility Latencies per Operation",
      "description": "Visibility task latencies broken down by operation on the History service.",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile($p, sum(rate(task_latency_bucket{operation=~\"VisibilityTask.*\",service_name=\"history\",namespace=\"$namespace\"}[$rate])) by (operation, le))", "legendFormat": "{{operation}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 86 },
      "id": 81,
      "title": "Visibility Availability",
      "description": "Percentage of visibility requests that succeeded (no errors).",
      "type": "timeseries",
      "targets": [
        { "expr": "100 - (sum(rate(service_errors{operation=~\"ListOpenWorkflowExecutions|ListClosedWorkflowExecutions|ListWorkflowExecutions|ScanWorkflowExecutions|CountWorkflowExecutions\",service_name=\"frontend\",namespace=\"$namespace\"}[$rate]) or on () vector(0)) / sum(rate(service_requests{operation=~\"ListOpenWorkflowExecutions|ListClosedWorkflowExecutions|ListWorkflowExecutions|ScanWorkflowExecutions|CountWorkflowExecutions\",service_name=\"frontend\",namespace=\"$namespace\"}[$rate])) * 100)", "legendFormat": "availability %", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 93 },
      "id": 82,
      "title": "Visibility Task End-to-End Latencies",
      "description": "End-to-end visibility task latencies (queue latency) broken down by operation on the History service.",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile($p, sum(rate(task_latency_queue_bucket{operation=~\"VisibilityTask.*\",service_name=\"history\",namespace=\"$namespace\"}[$rate])) by (operation, le))", "legendFormat": "{{operation}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 93 },
      "id": 83,
      "title": "Visibility Task Processing by Operation",
      "description": "Visibility task processing latencies broken down by operation on the History service.",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile($p, sum(rate(task_latency_bucket{operation=~\"VisibilityTask.*\",service_name=\"history\",namespace=\"$namespace\"}[$rate])) by (operation, le))", "legendFormat": "{{operation}}", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 100 },
      "id": 130,
      "title": "Task Timeouts",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 101 },
      "id": 131,
      "title": "Activity StartToClose Timeout",
      "description": "Rate of Activity StartToClose timeouts by namespace and operation.",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(start_to_close_timeout{operation=\"TimerActiveTaskActivityTimeout\",namespace=\"$namespace\"}[$rate])) by (namespace, operation)", "legendFormat": "{{namespace}} — {{operation}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 101 },
      "id": 132,
      "title": "Activity ScheduleToStart Timeout",
      "description": "Rate of Activity ScheduleToStart timeouts by namespace and operation.",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(schedule_to_start_timeout{operation=\"TimerActiveTaskActivityTimeout\",namespace=\"$namespace\"}[$rate])) by (namespace, operation)", "legendFormat": "{{namespace}} — {{operation}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 101 },
      "id": 133,
      "title": "Activity Heartbeat Timeout",
      "description": "Rate of Activity Heartbeat timeouts by namespace and operation.",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(heartbeat_timeout{operation=\"TimerActiveTaskActivityTimeout\",namespace=\"$namespace\"}[$rate])) by (namespace, operation)", "legendFormat": "{{namespace}} — {{operation}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 101 },
      "id": 134,
      "title": "Workflow Task StartToClose Timeouts per Namespace (sticky tq)",
      "description": "Rate of Workflow Task StartToClose timeouts per namespace and operation (sticky task queue).",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(start_to_close_timeout{operation=\"TimerActiveTaskWorkflowTaskTimeout\",namespace=\"$namespace\"}[$rate])) by (namespace, operation)", "legendFormat": "{{namespace}} — {{operation}}", "refId": "A" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["temporal", "prometheus"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(service_requests, namespace)",
        "hide": 0,
