{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 1, "title": "Server Overview — Cluster Throughput", "type": "row" },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 6, "x": 0, "y": 1 }, "id": 9, "title": "Server State Transitions", "description": "Server state transitions per second", "type": "timeseries", "targets": [ { "expr": "sum(rate(state_transition_count_count{namespace=\"$namespace\"}[$rate]))", "legendFormat": "state transitions/s", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 6, "x": 6, "y": 1 }, "id": 14, "title": "Shard Lock Latency", "description": "P99 latency for acquiring the shard lock (ShardInfo semaphore) on the History service.", "type": "timeseries", "targets": [ { "expr": "histogram_quantile($p, sum by (le) (rate(semaphore_latency_bucket{operation=\"ShardInfo\",service_name=\"history\",namespace=\"$namespace\"}[$rate])))", "legendFormat": "p{{p}} shard lock latency", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 6, "x": 12, "y": 1 }, "id": 15, "title": "Workflow Lock Latency", "description": "Cache latency for HistoryCacheGetOrCreate operation.", "type": "timeseries", "targets": [ { "expr": "histogram_quantile($p, sum(rate(cache_latency_bucket{operation=\"HistoryCacheGetOrCreate\",namespace=\"$namespace\"}[$rate])) by (le))", "legendFormat": "p{{p}} workflow lock latency", "refId": "A" } ] },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 }, "id": 7, "title": "Server Overview — Persistence Requests, Latencies and Errors", "type": "row" },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 6, "x": 0, "y": 9 }, "id": 70, "title": "Persistence Requests", "description": "Rate of persistence requests by operation.", "type": "timeseries", "targets": [ { "expr": "sum(rate(persistence_requests{namespace=\"$namespace\"}[$rate])) by (operation)", "legendFormat": "{{operation}}", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 6, "x": 6, "y": 9 }, "id": 71, "title": "Persistence Latencies", "description": "Persistence latencies broken down by operation.", "type": "timeseries", "targets": [ { "expr": "histogram_quantile($p, sum(rate(persistence_latency_bucket{namespace=\"$namespace\"}[$rate])) by (operation, le))", "legendFormat": "{{operation}}", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 6, "x": 12, "y": 9 }, "id": 72, "title": "Persistence Errors", "description": "Rate of persistence errors by operation and error type.", "type": "timeseries", "targets": [ { "expr": "sum(rate(persistence_error_with_type{namespace=\"$namespace\"}[$rate])) by (operation, error_type)", "legendFormat": "{{operation}} — {{error_type}}", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 6, "x": 18, "y": 9 }, "id": 73, "title": "Persistence Availability", "description": "Percentage of persistence requests that succeeded (no errors).", "type": "timeseries", "targets": [ { "expr": "100 - (sum(rate(persistence_errors{namespace=\"$namespace\"}[$rate]) or on () vector(0)) / sum(rate(persistence_requests{namespace=\"$namespace\"}[$rate])) * 100)", "legendFormat": "availability %", "refId": "A" } ] },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 }, "id": 90, "title": "Server Overview — Service Requests and Errors", "type": "row" },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 12, "x": 0, "y": 17 }, "id": 91, "title": "Service Requests", "description": "Rate of service requests on the Frontend service.", "type": "timeseries", "targets": [ { "expr": "sum(rate(service_requests{service_name=\"frontend\",namespace=\"$namespace\"}[$rate]) or on () vector(0))", "legendFormat": "requests/s", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 12, "x": 12, "y": 17 }, "id": 92, "title": "Service Errors", "description": "Rate of service errors on the Frontend service.", "type": "timeseries", "targets": [ { "expr": "sum(rate(service_errors{service_name=\"frontend\",namespace=\"$namespace\"}[$rate]) or on () vector(0))", "legendFormat": "errors/s", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 24, "x": 0, "y": 24 }, "id": 93, "title": "Service Requests by Namespace", "description": "Rate of frontend service requests broken down across all namespaces.", "type": "timeseries", "targets": [ { "expr": "sum by (namespace, operation) (rate(service_requests{service_name=\"frontend\"}[$rate]) or on () vector(0))", "legendFormat": "{{namespace}} — {{operation}}", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 24, "x": 0, "y": 31 }, "id": 94, "title": "Server Errors by Type", "description": "Rate of frontend service errors broken down by error type.", "type": "timeseries", "targets": [ { "expr": "sum by (error_type) (rate(service_error_with_type{service_name=\"frontend\",namespace=\"$namespace\"}[$rate]))", "legendFormat": "{{error_type}}", "refId": "A" } ] },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 }, "id": 100, "title": "Server Overview — Key API Latencies", "type": "row" },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 24, "x": 0, "y": 39 }, "id": 101, "title": "Key API Latencies by Operation", "description": "Latencies for key workflow and activity API operations on the Frontend service.", "type": "timeseries", "targets": [ { "expr": "histogram_quantile($p, sum by (operation, le) (rate(service_latency_bucket{operation=~\"StartWorkflowExecution|SignalWorkflowExecution|RespondWorkflowTaskCompleted|RespondActivityTaskCompleted\",service_name=\"frontend\",namespace=\"$namespace\"}[$rate])))", "legendFormat": "{{operation}}", "refId": "A" } ] },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 46 }, "id": 120, "title": "Server Overview — Throttling", "type": "row" },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 24, "x": 0, "y": 47 }, "id": 121, "title": "Resource Exhausted with Cause", "description": "Rate of resource exhausted errors broken down by operation and cause.", "type": "timeseries", "targets": [ { "expr": "sum(rate(service_errors_resource_exhausted{namespace=\"$namespace\"}[$rate])) by (operation, resource_exhausted_cause)", "legendFormat": "{{operation}} — {{resource_exhausted_cause}}", "refId": "A" } ] },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 54 }, "id": 140, "title": "Server Overview — Busy Workflow Throttling", "type": "row" },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 24, "x": 0, "y": 55 }, "id": 141, "title": "Transfer Active Task Errors Discarded", "description": "Rate of discarded task errors for active transfer operations.", "type": "timeseries", "targets": [ { "expr": "sum(rate(task_errors_discarded{operation=~\"TransferActive.*\",namespace=\"$namespace\"}[$rate]))", "legendFormat": "discarded errors/s", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 24, "x": 0, "y": 62 }, "id": 142, "title": "Transfer Active Task Errors Limit Exceeded", "description": "Rate of limit exceeded errors for active transfer operations.", "type": "timeseries", "targets": [ { "expr": "sum(rate(task_errors_limit_exceeded_counter{operation=~\"TransferActive.*\",namespace=\"$namespace\"}[$rate]))", "legendFormat": "limit exceeded/s", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 24, "x": 0, "y": 69 }, "id": 143, "title": "Transfer Active Task Errors Workflow Busy", "description": "Rate of workflow busy errors for active transfer operations.", "type": "timeseries", "targets": [ { "expr": "sum(rate(task_errors_workflow_busy{operation=~\"TransferActive.*\",namespace=\"$namespace\"}[$rate]))", "legendFormat": "workflow busy/s", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 24, "x": 0, "y": 76 }, "id": 144, "title": "Transfer Active Task Errors Throttled", "description": "Rate of throttled errors for active transfer operations, broken down by namespace and resource exhausted cause.", "type": "timeseries", "targets": [ { "expr": "sum(rate(task_errors_throttled{operation=~\"TransferActive.*\",namespace=\"$namespace\"}[$rate])) by (namespace, resource_exhausted_cause)", "legendFormat": "{{namespace}} — {{resource_exhausted_cause}}", "refId": "A" } ] },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 83 }, "id": 6, "title": "Server Overview — Shard Movement", "type": "row" },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 8, "x": 0, "y": 84 }, "id": 60, "title": "Shards Created", "description": "Rate of shard items created on the History service.", "type": "timeseries", "targets": [ { "expr": "sum(rate(sharditem_created_count{service_name=\"history\"}[$rate]))", "legendFormat": "shards created/s", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 8, "x": 8, "y": 84 }, "id": 61, "title": "Shards Removed", "description": "Rate of shard items removed on the History service.", "type": "timeseries", "targets": [ { "expr": "sum(rate(sharditem_removed_count{service_name=\"history\"}[$rate]))", "legendFormat": "shards removed/s", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 8, "x": 16, "y": 84 }, "id": 62, "title": "Shards Closed", "description": "Rate of shard items closed on the History service.", "type": "timeseries", "targets": [ { "expr": "sum(rate(sharditem_closed_count{service_name=\"history\"}[$rate]))", "legendFormat": "shards closed/s", "refId": "A" } ] },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 91 }, "id": 200, "title": "Server Overview — Workflow Stats", "type": "row" },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 4, "x": 0, "y": 92 }, "id": 201, "title": "Workflow Success", "type": "timeseries", "targets": [ { "expr": "sum(rate(workflow_success{namespace=\"$namespace\"}[$rate]))", "legendFormat": "success/s", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 4, "x": 4, "y": 92 }, "id": 202, "title": "Workflow Cancel", "type": "timeseries", "targets": [ { "expr": "sum(rate(workflow_cancel{namespace=\"$namespace\"}[$rate]))", "legendFormat": "cancel/s", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 4, "x": 8, "y": 92 }, "id": 203, "title": "Workflow Failed", "type": "timeseries", "targets": [ { "expr": "sum(rate(workflow_failed{namespace=\"$namespace\"}[$rate]))", "legendFormat": "failed/s", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 4, "x": 12, "y": 92 }, "id": 204, "title": "Workflow Timeout", "type": "timeseries", "targets": [ { "expr": "sum(rate(workflow_timeout{namespace=\"$namespace\"}[$rate]))", "legendFormat": "timeout/s", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 4, "x": 16, "y": 92 }, "id": 205, "title": "Workflow Terminate", "type": "timeseries", "targets": [ { "expr": "sum(rate(workflow_terminate{namespace=\"$namespace\"}[$rate]))", "legendFormat": "terminate/s", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 4, "x": 20, "y": 92 }, "id": 206, "title": "Workflow Continued As New", "type": "timeseries", "targets": [ { "expr": "sum(rate(workflow_continued_as_new{namespace=\"$namespace\"}[$rate]))", "legendFormat": "continued-as-new/s", "refId": "A" } ] },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 99 }, "id": 110, "title": "Server Overview — SDK Workers", "type": "row" },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 24, "x": 0, "y": 100 }, "id": 111, "title": "Schedule to Start Latencies", "description": "Latency from task scheduling to task start, broken down by task type and operation.", "type": "timeseries", "targets": [ { "expr": "histogram_quantile($p, sum(rate(task_schedule_to_start_latency_bucket{namespace=\"$namespace\"}[$rate])) by (task_type, operation, le))", "legendFormat": "{{task_type}} — {{operation}}", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 24, "x": 0, "y": 107 }, "id": 112, "title": "Tasks Persisted to DB (can indicate task backlog)", "description": "Rate of CreateTasks persistence requests. A sustained increase may indicate a task backlog building up.", "type": "timeseries", "targets": [ { "expr": "sum(rate(persistence_requests{operation=\"CreateTasks\",namespace=\"$namespace\"}[$rate]))", "legendFormat": "tasks persisted/s", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 24, "x": 0, "y": 114 }, "id": 113, "title": "Sync Match Rate", "description": "Sync match latency by operation on the Matching service.", "type": "timeseries", "targets": [ { "expr": "histogram_quantile($p, sum by (operation, le) (rate(syncmatch_latency_bucket{namespace=\"$namespace\",service_name=~\"matching\"}[$rate])))", "legendFormat": "{{operation}}", "refId": "A" } ] },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 121 }, "id": 130, "title": "Server Overview — Task Timeouts and Backlog", "type": "row" },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 6, "x": 0, "y": 122 }, "id": 131, "title": "Activity StartToClose Timeout", "description": "Rate of Activity StartToClose timeouts by namespace and operation.", "type": "timeseries", "targets": [ { "expr": "sum(rate(start_to_close_timeout{operation=\"TimerActiveTaskActivityTimeout\",namespace=\"$namespace\"}[$rate])) by (namespace, operation)", "legendFormat": "{{namespace}} — {{operation}}", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 6, "x": 6, "y": 122 }, "id": 132, "title": "Activity ScheduleToStart Timeout", "description": "Rate of Activity ScheduleToStart timeouts by namespace and operation.", "type": "timeseries", "targets": [ { "expr": "sum(rate(schedule_to_start_timeout{operation=\"TimerActiveTaskActivityTimeout\",namespace=\"$namespace\"}[$rate])) by (namespace, operation)", "legendFormat": "{{namespace}} — {{operation}}", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 6, "x": 12, "y": 122 }, "id": 133, "title": "Activity Heartbeat Timeout", "description": "Rate of Activity Heartbeat timeouts by namespace and operation.", "type": "timeseries", "targets": [ { "expr": "sum(rate(heartbeat_timeout{operation=\"TimerActiveTaskActivityTimeout\",namespace=\"$namespace\"}[$rate])) by (namespace, operation)", "legendFormat": "{{namespace}} — {{operation}}", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 6, "x": 18, "y": 122 }, "id": 134, "title": "Workflow Task StartToClose Timeouts per Namespace (sticky tq)", "description": "Rate of Workflow Task StartToClose timeouts per namespace and operation (sticky task queue).", "type": "timeseries", "targets": [ { "expr": "sum(rate(start_to_close_timeout{operation=\"TimerActiveTaskWorkflowTaskTimeout\",namespace=\"$namespace\"}[$rate])) by (namespace, operation)", "legendFormat": "{{namespace}} — {{operation}}", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 24, "x": 0, "y": 129 }, "id": 135, "title": "Approximate Task Backlog", "description": "Approximate backlog count by namespace and task type on the Matching service.", "type": "timeseries", "targets": [ { "expr": "sum by (namespace, task_type) (approximate_backlog_count{service_name=~\"matching\",namespace=\"$namespace\"})", "legendFormat": "{{namespace}} — {{task_type}}", "refId": "A" } ] },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 136 }, "id": 150, "title": "Server Overview — Schedules", "type": "row" },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 24, "x": 0, "y": 137 }, "id": 151, "title": "Schedule Action Success", "description": "Rate of successful schedule actions broken down by schedule action type, across all namespaces.", "type": "timeseries", "targets": [ { "expr": "sum by (schedule_action) (rate(schedule_action_success{}[$rate]))", "legendFormat": "{{schedule_action}}", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 24, "x": 0, "y": 144 }, "id": 152, "title": "Number of Namespaces Using Schedules", "description": "Count of distinct namespaces that have recorded successful schedule actions.", "type": "timeseries", "targets": [ { "expr": "count(count by (namespace) (schedule_action_success{}))", "legendFormat": "namespaces", "refId": "A" } ] },
    { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [] }, "gridPos": { "h": 7, "w": 24, "x": 0, "y": 151 }, "id": 153, "title": "Schedule Action Success by Namespace", "description": "Top 10 namespaces by rate of successful schedule actions.", "type": "timeseries", "targets": [ { "expr": "topk(10, sum by (namespace) (rate(schedule_action_success{namespace=~\"$namespace\"}[$rate])))", "legendFormat": "{{namespace}}", "refId": "A" } ] },
